#!/bin/sh
set -eu

PORT="${OPENSCANSTATION_PORT:-8101}"
URL="http://127.0.0.1:${PORT}/health"

if /usr/bin/python3 - "$URL" <<'PY'
import json
import sys
import urllib.request

url = sys.argv[1]
try:
    with urllib.request.urlopen(url, timeout=8) as response:
        payload = json.load(response)
    if response.status != 200 or payload.get("status") != "ok":
        raise RuntimeError("ungültige Health-Antwort")
except Exception as exc:
    print(f"OpenScanStation Health-Check fehlgeschlagen: {exc}", file=sys.stderr)
    raise SystemExit(1)
PY
then
    exit 0
fi

/usr/bin/systemctl restart openscanstation.service
sleep 3
/usr/bin/python3 - "$URL" <<'PY'
import json
import sys
import urllib.request

with urllib.request.urlopen(sys.argv[1], timeout=8) as response:
    payload = json.load(response)
if response.status != 200 or payload.get("status") != "ok":
    raise SystemExit(1)
PY
